---
import '../../styles/global.css';
import GenericPlaygroundApp from '../../components/react/playground/GenericPlaygroundApp';
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Generic RAG Playground | LearnRAG</title>
    <meta name="description" content="Interactive RAG pipeline playground. Ingest documents, chunk them, embed with AI, search by meaning, and generate grounded answers — all in your browser." />
    <meta name="theme-color" content="#16131e" />
    <link rel="canonical" href="https://learnrag.online/playground/generic/" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://learnrag.online/playground/generic/" />
    <meta property="og:title" content="RAG Playground | LearnRAG" />
    <meta property="og:description" content="Ingest, chunk, embed, search, and generate — entirely in your browser. No API keys. No setup." />
    <meta property="og:image" content="https://learnrag.online/Thumbnail.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="LearnRAG — Build a RAG app. Right here. Right now." />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://learnrag.online/Thumbnail.png" />
    <meta name="twitter:image:alt" content="LearnRAG — Build a RAG app. Right here. Right now." />
