---
import '../../styles/global.css';
import PlaygroundApp from '../../components/react/playground/PlaygroundApp';
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Salesforce Data Cloud Playground | LearnRAG</title>
    <meta name="description" content="Interactive Salesforce Data Cloud RAG pipeline playground. See how unstructured data flows through UDLO, UDMO, chunking, and vector search — all in your browser." />
    <meta name="theme-color" content="#16131e" />
    <link rel="canonical" href="https://learnrag.online/playground/salesforce/" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://learnrag.online/playground/salesforce/" />
    <meta property="og:title" content="Salesforce Data Cloud RAG Playground | LearnRAG" />
    <meta property="og:description" content="Explore the full Salesforce Data Cloud unstructured RAG pipeline — Data Stream → DLO → DMO → Chunking → Embedding → Retrieval." />
    <meta property="og:image" content="https://learnrag.online/Thumbnail.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="LearnRAG — Salesforce Data Cloud RAG Playground" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://learnrag.online/Thumbnail.png" />
    <meta name="twitter:image:alt" content="LearnRAG — Salesforce Data Cloud RAG Playground" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body style="margin: 0; background: #16131e;">
    <PlaygroundApp client:load />
  </body>
</html>
