---
// Custom Starlight Head override: extends default Head, adds per-page Article + Breadcrumb schema
import Default from '@astrojs/starlight/components/Head.astro';

const route = Astro.locals.starlightRoute;
const title = route?.entry?.data?.title ?? '';
const description = route?.entry?.data?.description ?? '';
const pageUrl = new URL(Astro.url.pathname, 'https://learnrag.online').href;

const pathParts = Astro.url.pathname.replace(/^\/|\/$/g, '').split('/');
const sectionLabel = pathParts[0]
  ? pathParts[0].charAt(0).toUpperCase() + pathParts[0].slice(1)
  : 'Learn';
const sectionUrl = `https://learnrag.online/${pathParts[0] ?? ''}/`;
---

<Default {...Astro.props}><slot /></Default>
<script is:inline>
  // Force dark theme - block any theme switching
  (function() {
    // Set theme immediately
    document.documentElement.setAttribute('data-theme', 'dark');

    // Override localStorage to prevent theme persistence
    const originalSetItem = localStorage.setItem;
    localStorage.setItem = function(key, value) {
      if (key.includes('theme') || key.includes('starlight')) {
        return; // Block theme-related storage
      }
      return originalSetItem.apply(this, arguments);
    };

    // Clear any existing theme preference
    try {
      Object.keys(localStorage).forEach(key => {
        if (key.includes('theme') || key.includes('starlight-theme')) {
          localStorage.removeItem(key);
        }
      });
    } catch (e) {}

    // Watch for any theme changes and force it back to dark
    const observer = new MutationObserver(function(mutations) {
      mutations.forEach(function(mutation) {
        if (mutation.attributeName === 'data-theme') {
          const current = document.documentElement.getAttribute('data-theme');
          if (current !== 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
          }
        }
      });
    });

    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme']
    });
  })();
</script>
<script defer src="https://cloud.umami.is/script.js" data-website-id="524a89b4-6608-448c-ac06-18c1b4be351b"></script>
<script type="application/ld+json" set:html={title ? JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  url: pageUrl,
  inLanguage: 'en',
  isAccessibleForFree: true,
  publisher: { '@type': 'Organization', name: 'LearnRAG', url: 'https://learnrag.online' },
  isPartOf: { '@type': 'Course', name: 'LearnRAG — Retrieval-Augmented Generation', url: 'https://learnrag.online' },
}) : ''}></script>
<script type="application/ld+json" set:html={title ? JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'LearnRAG', item: 'https://learnrag.online' },
    { '@type': 'ListItem', position: 2, name: sectionLabel, item: sectionUrl },
    { '@type': 'ListItem', position: 3, name: title, item: pageUrl },
  ],
}) : ''}></script>
